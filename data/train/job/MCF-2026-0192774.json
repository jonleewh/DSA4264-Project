{
  "uuid": "3fdf2f5ac8c025b03a7cf4875e08c7e9",
  "sourceCode": "Employer Portal",
  "title": "SUPERVISOR",
  "description": "<ul><li>Carry out in-process quality checks.</li></ul><ul><li>Check finished components for defects and compliance with required specifications.</li></ul><ul><li>Check machining parameters for assembly jobs.</li></ul><ul><li>Check operational readiness of production equipment and machinery.</li></ul><ul><li>Coordinate classification society surveys in the presence of ship owners.</li></ul><ul><li>Coordinate construction of launching cradles.</li></ul><ul><li>Coordinate erection of supports for assembly works.</li></ul><ul><li>Coordinate fastening of loose items onboard ships and rigs before launch.</li></ul><ul><li>Coordinate installation processes with other production teams.</li></ul><ul><li>Coordinate movement of hull blocks into designated work areas.</li></ul><ul><li>Dispose post-operation wastes in accordance with safe working practices and approved procedures.</li></ul><ul><li>Ensure correct work materials are used and components are assembled in accordance with drawings, instructions and workflow plans.</li></ul><ul><li>Measure manufactured components for conformance with specifications before assembly.</li></ul><ul><li>Monitor operations, and make adjustments to achieve desired quality.</li></ul><ul><li>Prepare launch ways.</li></ul><ul><li>Raise request orders for spare parts.</li></ul><ul><li>Schedule servicing, overhaul and replacement jobs.</li></ul><ul><li>Supervise workers for appropriate use of materials, machining techniques and compliance with work instructions and Workplace Safety and Health (WSH) requirements.</li></ul><ul><li>Transfer ship and rig loads to launch ways.</li></ul><ul><li>Verify correctness of final manufactured components against specifications.</li></ul>",
  "minimumYearsExperience": 3,
